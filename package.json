{
  "name": "gtnh-idle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "csv":        "node tools/csv-runner.cjs",
    "locale:sort": "node tools/sort-locale.cjs",
    "docs:auto": "node tools/docs-sync.cjs --auto",
    "docs:check": "node tools/docs-sync.cjs --check",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "pinia": "^2.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue-tsc": "^2.0.0"
  }
}
